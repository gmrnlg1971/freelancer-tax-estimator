							</div>
							<span class="font-bold text-slate-800" id="out-se-tax">$0</span>
						</div>
						<div class="flex justify-between items-center pb-3 border-b border-slate-100">
							<div class="flex items-center gap-2">
								<div class="w-3 h-3 rounded-full bg-indigo-500"></div>
								<span class="text-slate-600 font-medium">Federal Income Tax</span>
							</div>
							<span class="font-bold text-slate-800" id="out-fed-tax">$0</span>
						</div>
						<div class="flex justify-between items-center pb-3 border-b border-slate-100">
							<div class="flex items-center gap-2">
								<div class="w-3 h-3 rounded-full bg-amber-500"></div>
								<span class="text-slate-600 font-medium">State Income Tax</span>
							</div>
							<span class="font-bold text-slate-800" id="out-state-tax">$0</span>
						</div>
						<div class="flex justify-between items-center pt-2">
							<span class="text-slate-800 font-bold">Total Estimated Tax</span>
							<span class="font-extrabold text-red-500 text-lg" id="out-total-tax">$0</span>
						</div>
					</div>

					<!-- Visual Bar -->
					<div class="mt-6 pt-6 border-t border-slate-100">
						<div class="h-4 w-full bg-slate-100 rounded-full overflow-hidden flex" id="visual-bar">
							<div class="bg-emerald-500 h-full" id="bar-take-home" style="width: 60%"></div>
							<div class="bg-blue-500 h-full" id="bar-se-tax" style="width: 15%"></div>
							<div class="bg-indigo-500 h-full" id="bar-fed-tax" style="width: 10%"></div>
							<div class="bg-amber-500 h-full" id="bar-state-tax" style="width: 10%"></div>
							<div class="bg-slate-300 h-full" id="bar-expenses" style="width: 5%"></div>
						</div>
						<div class="flex justify-between text-[10px] sm:text-xs text-slate-500 mt-2 font-medium">
							<span>Take Home</span>
							<span>SE</span>
							<span>Fed</span>
							<span>State</span>
							<span>Exp</span>
						</div>
					</div>
					
					<p class="text-[10px] text-slate-400 mt-4 text-center leading-tight">
						*This is a simplified estimate for 2026 using the standard deduction. It does not include state income taxes, local taxes, or the Qualified Business Income (QBI) deduction. Consult a CPA for official tax advice.
					</p>
				</div>
			</div>
		</div>
	</div>
</Layout>

