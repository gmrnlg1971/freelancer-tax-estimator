---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Freelancer Tax Estimator | 1099 Tax Calculator">
	<div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
		<div class="text-center mb-10">
			<h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-slate-900">
				Freelancer <span class="text-emerald-600">Tax Estimator</span>
			</h1>
			<p class="text-lg text-slate-600 max-w-2xl mx-auto">Instantly calculate your 1099 taxes, self-employment tax, and take-home pay based on 2026 US tax brackets.</p>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
			<!-- Input Section (Left) -->
			<div class="lg:col-span-5 space-y-6">
				<div class="fintech-card p-6">
					<h2 class="text-lg font-bold text-slate-800 mb-4 border-b border-slate-100 pb-2">Your Details</h2>
					
					<div class="space-y-5">
						<div>
							<label for="gross-income" class="block text-sm font-semibold text-slate-700 mb-1">Gross Annual Income</label>
							<div class="relative">
								<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
									<span class="text-slate-400 font-medium">$</span>
								</div>
								<input type="number" id="gross-income" class="input-field !pl-8 font-medium" placeholder="75000" min="0" value="75000" />
							</div>
							<p class="text-xs text-slate-500 mt-1">Total 1099-NEC earnings before expenses.</p>
						</div>

						<div>
							<label for="expenses" class="block text-sm font-semibold text-slate-700 mb-1">Business Expenses</label>
							<div class="relative">
								<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
									<span class="text-slate-400 font-medium">$</span>
								</div>
								<input type="number" id="expenses" class="input-field !pl-8 font-medium" placeholder="5000" min="0" value="5000" />
							</div>
							<p class="text-xs text-slate-500 mt-1">Deductible business write-offs.</p>
						</div>

						<div>
							<label for="filing-status" class="block text-sm font-semibold text-slate-700 mb-1">Filing Status</label>
							<select id="filing-status" class="input-field font-medium bg-white">
								<option value="single">Single</option>
								<option value="married">Married Filing Jointly</option>
							</select>
							<p class="text-xs text-slate-500 mt-1">Determines your federal standard deduction.</p>
						</div>

						<div>
							<label for="state" class="block text-sm font-semibold text-slate-700 mb-1">State (For State Tax)</label>
							<select id="state" class="input-field font-medium bg-white">
<option value="AL">Alabama</option>
