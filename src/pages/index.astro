	function calculateTaxes() {
		const grossIncome = parseFloat((document.getElementById('gross-income') as HTMLInputElement).value) || 0;
		const expenses = parseFloat((document.getElementById('expenses') as HTMLInputElement).value) || 0;
		const filingStatus = (document.getElementById('filing-status') as HTMLSelectElement).value as 'single' | 'married';
		const state = (document.getElementById('state') as HTMLSelectElement).value;

		const netProfit = Math.max(0, grossIncome - expenses);

		// Self Employment Tax (15.3% on 92.35% of net profit)
		const seTaxableIncome = netProfit * 0.9235;
		let seTax = 0;
		if (seTaxableIncome > 400) {
			// Simplified: Ignoring the Social Security wage base limit ($175,000 for 2026) for simplicity, 
			// but we can add it for accuracy if needed. Let's add it.
			const ssWageBase = 168600;
			const ssTax = Math.min(seTaxableIncome, ssWageBase) * 0.124;
			const medicareTax = seTaxableIncome * 0.029;
			seTax = ssTax + medicareTax;
		}

		// Federal Income Tax
		const seTaxDeduction = seTax / 2;
		const stdDeduction = standardDeduction2026[filingStatus];
		const taxableIncome = Math.max(0, netProfit - seTaxDeduction - stdDeduction);

		let federalTax = 0;
		let previousLimit = 0;
		const brackets = brackets2026[filingStatus];

		for (const bracket of brackets) {
			if (taxableIncome > previousLimit) {
				const taxableAmountInBracket = Math.min(taxableIncome, bracket.limit) - previousLimit;
				federalTax += taxableAmountInBracket * bracket.rate;
				previousLimit = bracket.limit;
			} else {
				break;
			}
		}

		// State Income Tax
		let stateTax = 0;
		const stateData = stateTaxData[state];
		if (stateData) {
			if (stateData.type === "flat") {
				// Flat tax usually applies to net profit or taxable income. We use taxable income to be safe/conservative.
				stateTax = taxableIncome * stateData.rate;
			} else if (stateData.type === "progressive") {
				const stateTaxableIncome = Math.max(0, netProfit - seTaxDeduction - stateData.std);
				let sPrevLimit = 0;
				for (const bracket of stateData.brackets) {
					if (stateTaxableIncome > sPrevLimit) {
						const sAmount = Math.min(stateTaxableIncome, bracket.limit) - sPrevLimit;
						stateTax += sAmount * bracket.rate;
						sPrevLimit = bracket.limit;
					} else {
						break;
					}
				}
			}
		}

		const totalTax = seTax + federalTax + stateTax;
		const takeHome = netProfit - totalTax;
		const effectiveRate = grossIncome > 0 ? (totalTax / grossIncome) * 100 : 0;

		// Update UI
		document.getElementById('out-net-profit')!.textContent = formatUSD(netProfit);
		document.getElementById('out-se-tax')!.textContent = formatUSD(seTax);
		document.getElementById('out-fed-tax')!.textContent = formatUSD(federalTax);
		document.getElementById('out-state-tax')!.textContent = formatUSD(stateTax);
		document.getElementById('out-total-tax')!.textContent = formatUSD(totalTax);
		document.getElementById('out-take-home')!.textContent = formatUSD(takeHome);
		document.getElementById('out-effective-rate')!.textContent = `Effective Tax Rate: ${effectiveRate.toFixed(1)}%`;

		// Update Visual Bar
		if (grossIncome > 0) {
			const takeHomePct = (takeHome / grossIncome) * 100;
			const seTaxPct = (seTax / grossIncome) * 100;
			const fedTaxPct = (federalTax / grossIncome) * 100;
			const stateTaxPct = (stateTax / grossIncome) * 100;
			const expPct = (expenses / grossIncome) * 100;

			document.getElementById('bar-take-home')!.style.width = `${Math.max(0, takeHomePct)}%`;
			document.getElementById('bar-se-tax')!.style.width = `${Math.max(0, seTaxPct)}%`;
			document.getElementById('bar-fed-tax')!.style.width = `${Math.max(0, fedTaxPct)}%`;
			document.getElementById('bar-state-tax')!.style.width = `${Math.max(0, stateTaxPct)}%`;
			document.getElementById('bar-expenses')!.style.width = `${Math.max(0, expPct)}%`;
		} else {
			document.getElementById('bar-take-home')!.style.width = '0%';
			document.getElementById('bar-se-tax')!.style.width = '0%';
			document.getElementById('bar-fed-tax')!.style.width = '0%';
			document.getElementById('bar-state-tax')!.style.width = '0%';
			document.getElementById('bar-expenses')!.style.width = '0%';
		}
	}

	// Listeners
	document.addEventListener('DOMContentLoaded', () => {
		const inputs = ['gross-income', 'expenses', 'filing-status', 'state'];
