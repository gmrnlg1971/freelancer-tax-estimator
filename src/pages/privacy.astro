---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Privacy Policy - 1099TaxEst">
	<div class="max-w-3xl mx-auto px-4 py-16">
		<h1 class="text-3xl font-bold text-slate-900 mb-6">Privacy Policy</h1>
		<div class="fintech-card p-8 prose prose-slate max-w-none">
			<p><strong>Last Updated: {new Date().toLocaleDateString()}</strong></p>
			<h2>Data Processing</h2>
			<p>Our tax calculator operates 100% locally in your browser using JavaScript. When you input your income and expenses, the calculations happen on your device. We do not transmit, store, track, or log any of your financial data.</p>
			<h2>Analytics and Advertising</h2>
			<p>We may use third-party tools such as Google Analytics to monitor traffic and Google AdSense to display advertisements. These services may use cookies to serve personalized ads based on your visit to our site and other sites on the internet.</p>
			<h2>Your Rights</h2>
			<p>You can opt out of personalized advertising by visiting Google's Ads Settings.</p>
		</div>
	</div>
</Layout>
